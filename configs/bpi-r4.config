CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_bananapi_bpi-r4=y

# Disable multi-profile to avoid fallback to openwrt_one
CONFIG_TARGET_MULTI_PROFILE=n

# Images
CONFIG_TARGET_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y

# Root filesystem types (required for SD card image)
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y

# Increase rootfs size (adjust if needed)
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# Keep minimal packages (can be customized)
CONFIG_TARGET_DEVICE_PACKAGES_mediatek_filogic_DEVICE_bananapi_bpi-r4=""

# Build options
CONFIG_DEVEL=y
CONFIG_AUTOREMOVE=y
