CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y

# REQUIRED: architecture
CONFIG_ARCH_MEDIATEK=y

# REQUIRED: select correct SoC family (MT7988 for BPI-R4)
CONFIG_TARGET_mediatek_filogic_MT7988=y

# Device
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_bananapi_bpi-r4=y

# Disable fallback profile
CONFIG_TARGET_MULTI_PROFILE=n

# Image formats (needed for SD card)
CONFIG_TARGET_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# Optional but recommended
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# Build options
CONFIG_DEVEL=y
CONFIG_AUTOREMOVE=y
